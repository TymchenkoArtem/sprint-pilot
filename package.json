{
  "name": "sprint-pilot",
  "version": "1.0.7",
  "description": "Security-scoped MCP server for Azure DevOps development workflow automation",
  "keywords": [
    "mcp",
    "azure-devops",
    "automation",
    "ai",
    "claude",
    "fabric"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TymchenkoArtem/sprint-pilot.git"
  },
  "homepage": "https://github.com/TymchenkoArtem/sprint-pilot#readme",
  "bugs": {
    "url": "https://github.com/TymchenkoArtem/sprint-pilot/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sprint-pilot": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run tests/security/ --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build && npm run test && npm run typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "keytar": "^7.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
